---
import Layout from '../layouts/Layout.astro'
import IconCard from '../components/IconCard.astro'

import { google, ics } from 'calendar-link'
import type { CalendarEvent } from 'calendar-link'

const calendarEvent: CalendarEvent = {
    title: "Flow vol." + 10,
    description: "オーディオビジュアルイベント『Flow』の第" + 10 + "回。",
    location: "567-8570　大阪府茨木市岩倉町2-150",
    start: "2026-3-14 12:00:00 +0900",
    duration: [8, "hours"],
    rRule: "FREQ=DAILY;COUNT=2"
}

const gCalendarLink = google(calendarEvent)
const iCalendarLink = ics(calendarEvent)

import { Icon } from 'astro-icon/components'

---

<Layout
    title="Flow"
	desc="Fellowによるオーディオビジュアルパフォーマンスイベント、FLOWのウェブページ"
	favicon='/favicon.ico'
	>

    <main class="font-nijimi text-white min-h-screen">
        <div class="inner py-24 min-h-screen h-full mx-5 xl:mx-56">
            <h1 class="m-0 flex flex-col items-center">
                <img class="flicker w-1/2" src="/images/Flow_Logo_Large.webp" alt="FLOWのロゴ">
            </h1>
            <div class="flex flex-col">
                <p class="text-center text-lg my-3">
                    Flow vol.10は<br>2026/3/14 ～ 15,　12:00pm open!
                </p>
                <p>詳細は公式アカウント、Discordサーバーへ</p>
                <div class="flex justify-center items-center my-3 gap-x-3">
                    <span>カレンダーへ追加: </span>
                    <a href=`${gCalendarLink}`}><Icon class="inline-block w-8 h-auto" name="fa7-brands:google" /></a>
                    <a href=`${iCalendarLink}`}><Icon class="inline-block w-8 h-auto" name="fa7-brands:apple" /></a>
                </div>
            </div>
            <div class="linkGrid grid grid-cols-1 md:grid-cols-2 gap-x-5 gap-y-3">
                <IconCard
                    iconName='fa7-brands:x-twitter'
                    title='Flow 公式Twitter'
                    body='開催情報をはじめ関連する情報を発信中！'
                    href='https://x.com/flow_fellow/'
                />
                <IconCard
                    iconName='fa7-brands:instagram'
                    title='Flow 公式Instagram'
                    body='Instagramでも情報発信中！'
                    href='https://www.instagram.com/flow._.fellow/'
                />
                <IconCard
                    iconName='fa7-brands:discord'
                    title='Flow 公式Discordサーバー'
                    body='より細かい情報や、関連イベント情報を発信します！'
                    href='https://discord.gg/XCqhqjks9c'
                />
                <IconCard
                    iconName='fa7-brands:youtube'
                    title='Flow 公式YouTubeチャンネル'
                    body='公開されている各回のアーカイブを閲覧できます。'
                    href='https://www.youtube.com/@fellow.flow.2025'
                />
            </div>
        </div>
    </main>

</Layout>

<style>
    .inner{
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;

        row-gap: 100px;
    }
</style>